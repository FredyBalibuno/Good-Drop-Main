# MongoDB Atlas → Connect → Drivers → Node.js copy connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority&appName=GoodDrop

# Optional: database name (default: gooddrop)
MONGODB_DB=gooddrop

# API port (default: 3001). Vite proxies /api here in dev.
PORT=3001

# Optional: lock CORS to your deployed app origin in production
# CORS_ORIGIN=https://your-app.example

# Production Vite build: set to your deployed API origin (no trailing slash)
# VITE_API_BASE=https://api.your-app.example
